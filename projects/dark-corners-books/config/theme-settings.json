{
  "name": "Dark Corners Books",
  "description": "Horror fiction that keeps the lights on. Independent horror publisher — cosmic, folk, psychological, and supernatural terror.",
  "theme": "Dawn",
  "color_scheme": {
    "background": "#0a0a0a",
    "text": "#e0d6c8",
    "accent": "#b22222",
    "accent_hover": "#8b0000",
    "secondary": "#2a1a1a",
    "border": "#2a2020",
    "header_bg": "#080808",
    "footer_bg": "#080808",
    "card_bg": "#111111",
    "sale_badge": "#b22222",
    "button_primary": "#b22222",
    "button_text": "#ffffff",
    "muted_text": "#8a7e72",
    "star_color": "#c9a84c"
  },
  "typography": {
    "heading_font": "Georgia, serif",
    "body_font": "-apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
    "heading_weight": 700,
    "body_size": "16px",
    "heading_scale": 1.3
  },
  "layout": {
    "max_width": "1200px",
    "grid_columns": 3,
    "product_card_ratio": "3:4",
    "spacing": "24px"
  },
  "features": {
    "sticky_header": true,
    "cart_type": "drawer",
    "quick_view": false,
    "product_recommendations": true,
    "newsletter_popup": false,
    "age_gate": true
  }
}
